{
  "name": "@whiskeysockets/libsignal-node",
  "version": "2.0.1",
  "description": "Open Whisper Systems' libsignal for Node.js",
  "repository": "WhiskeySockets/libsignal-node",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    }
  },
  "types": "index.d.ts",
  "keywords": [
    "signal",
    "whispersystems",
    "crypto"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "GPL-3.0",
  "scripts": {
    "install": "node scripts/build-native.js",
    "build:native": "node scripts/build-native.js",
    "lint": "eslint src/*.js index.js",
    "build:proto:cpp": "node scripts/build-proto-cpp.js"
  },
  "dependencies": {
    "@unknownncat/curve25519-node": "^2.1.2",
    "node-addon-api": "^8.3.1"
  },
  "files": [
    "index.js",
    "src/*",
    "native/*",
    "native/proto/*",
    "scripts/*",
    "binding.gyp",
    "index.d.ts"
  ],
  "devDependencies": {
    "eslint": "^8.57.1"
  }
}
